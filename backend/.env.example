# WebMD 环境变量示例（复制为 backend/.env 后按需修改）
# 生产部署务必设置 WEBMD_ENV=production，并替换所有默认密钥

# 运行环境：development | production（production 会拒绝默认密钥）
WEBMD_ENV=development

# 站点公网地址（CORS 与邮件链接）
WEBMD_SITE_URL=http://localhost:8000

# 认证与管理员
WEBMD_JWT_SECRET=请替换为足够长的随机字符串
WEBMD_JWT_EXPIRE_DAYS=14
WEBMD_ADMIN_KEY=请替换为强管理员密钥
WEBMD_MD_CALLBACK_SECRET=请替换为 MD 回调校验密钥

# 付费
WEBMD_PAYMENT_ENABLED=1
WEBMD_MD_PRICE=240
WEBMD_MD_MAX_NS=200
WEBMD_TIP_ENABLED=0

# 前处理限流
WEBMD_MAX_ACTIVE_PREP_TASKS=10
WEBMD_MAX_PROTEIN_RESIDUES=1000
WEBMD_PROTEIN_AA_LIMIT_EXEMPT_EMAILS=

# 邮件（管理员通知 / 用户结果）
WEBMD_ADMIN_NOTIFY_EMAIL=
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# AutoDL（可选；任务级 SSH 密码仅存内存，不写 task_meta）
AUTODL_SSH_HOST=
AUTODL_SSH_PORT=22
AUTODL_SSH_USER=root
AUTODL_SSH_PASSWORD=
AUTODL_REMOTE_DIR=/root/webmd_jobs
AUTODL_MAX_CONCURRENT=2

# 启动行为开关（1=跳过）
WEBMD_SKIP_AUTODL_DISPATCH=0
WEBMD_SKIP_AMBER_REPAIR=0
WEBMD_SKIP_TASK_CLEANUP=0

# 任务目录自动清理（超过天数删除；默认每天检查一次）
WEBMD_TASK_RETENTION_DAYS=7
WEBMD_TASK_CLEANUP_INTERVAL_SEC=86400
